# Binaries
bin/
dist/
# Generated shell completions + man pages (produced by `go run ./cmd/gen-docs`
# at release time; kept out of dist/ so GoReleaser's empty-dist check passes).
extras/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work
go.work.sum

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build
vendor/

# Cache
cache.json

# Coverage
coverage.out
coverage.html

# Fuzz
testdata/fuzz/

# Marketplace (assembled from marketplace/tools/ and marketplace/packs/ by CI)
/marketplace.yaml

# Node.js (any subdir that hosts a Node toolchain, e.g. local prototypes)
node_modules/

# Environment
.env
.env.*
