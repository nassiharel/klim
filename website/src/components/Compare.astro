---
const rows = [
  {
    capability: 'List all installed CLIs',
    pkgMgr: 'Only their own',
    verMgr: 'Only managed tools',
    scripts: 'Fragile',
    clim: 'All detected tools',
  },
  {
    capability: 'Show versions',
    pkgMgr: 'Per-manager',
    verMgr: 'Per-manager',
    scripts: 'Partial',
    clim: 'Unified view',
  },
  {
    capability: 'Show install paths',
    pkgMgr: '✗',
    verMgr: '✗',
    scripts: 'Manual',
    clim: 'Automatic',
  },
  {
    capability: 'Cross-manager support',
    pkgMgr: '✗',
    verMgr: 'Limited',
    scripts: '✗',
    clim: '7 managers',
  },
  {
    capability: 'Upgrade suggestions',
    pkgMgr: 'Per-manager',
    verMgr: 'Per-manager',
    scripts: '✗',
    clim: 'Single view',
  },
  {
    capability: 'Export/Import toolchain',
    pkgMgr: '✗',
    verMgr: 'Partial',
    scripts: '✗',
    clim: 'YAML manifest',
  },
  {
    capability: 'Interactive TUI',
    pkgMgr: '✗',
    verMgr: '✗',
    scripts: '✗',
    clim: 'Full TUI',
  },
  {
    capability: 'Team standardization',
    pkgMgr: '✗',
    verMgr: 'Partial',
    scripts: '✗',
    clim: '.clim.yaml',
  },
  {
    capability: 'Per-tool detail (sources, GitHub, refs)',
    pkgMgr: 'Per-manager only',
    verMgr: '✗',
    scripts: '✗',
    clim: 'clim info',
  },
  {
    capability: 'Toolchain history & diff',
    pkgMgr: '✗',
    verMgr: '✗',
    scripts: 'Manual',
    clim: 'clim trail',
  },
];
---

<section id="compare" class="py-20 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        How clim compares
      </h2>
      <p class="mt-4 text-lg text-gray-400">
        clim complements your existing tools — it doesn't replace them.
      </p>
    </div>

    <div class="mt-12 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-gray-800">
            <th class="px-4 py-3 font-medium text-gray-400">Capability</th>
            <th class="px-4 py-3 font-medium text-gray-400">Package Managers</th>
            <th class="px-4 py-3 font-medium text-gray-400">Version Managers</th>
            <th class="px-4 py-3 font-medium text-gray-400">Ad-hoc Scripts</th>
            <th class="px-4 py-3 font-medium text-green-400">clim</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-gray-800/50">
              <td class="px-4 py-3 text-gray-300">{row.capability}</td>
              <td class="px-4 py-3 text-gray-500">{row.pkgMgr}</td>
              <td class="px-4 py-3 text-gray-500">{row.verMgr}</td>
              <td class="px-4 py-3 text-gray-500">{row.scripts}</td>
              <td class="px-4 py-3 font-medium text-green-400">{row.clim}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
