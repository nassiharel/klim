---
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-32">
  <!-- Gradient background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-green-500/10 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="mb-6 inline-flex items-center rounded-full border border-green-500/20 bg-green-500/10 px-4 py-1.5 text-sm text-green-400">
      Open source CLI tool manager
    </div>

    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
      One command to manage
      <span class="bg-gradient-to-r from-green-400 to-emerald-400 bg-clip-text text-transparent">
        every CLI
      </span>
      on your system
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-400 md:text-xl">
      klim discovers, inspects, and upgrades 110+ developer tools across
      macOS, Linux, and Windows — using your native package managers.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#install"
        class="inline-flex items-center rounded-lg bg-green-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-green-500/25 transition-all hover:bg-green-400 hover:shadow-green-500/40"
      >
        Get Started
      </a>
      <a
        href="https://docs.klim.dev"
        class="inline-flex items-center rounded-lg border border-gray-700 px-6 py-3 text-sm font-semibold text-gray-300 transition-all hover:border-gray-500 hover:text-white"
      >
        Read the Docs →
      </a>
    </div>

    <!-- Terminal preview -->
    <div class="mx-auto mt-16 max-w-3xl overflow-hidden rounded-xl border border-gray-800 bg-gray-900 shadow-2xl">
      <div class="flex items-center gap-2 border-b border-gray-800 px-4 py-3">
        <div class="h-3 w-3 rounded-full bg-red-500/60"></div>
        <div class="h-3 w-3 rounded-full bg-yellow-500/60"></div>
        <div class="h-3 w-3 rounded-full bg-green-500/60"></div>
        <span class="ml-2 text-xs text-gray-500">Terminal</span>
      </div>
      <div class="p-6 text-left font-mono text-sm leading-relaxed">
        <p class="text-gray-500">$ klim</p>
        <p class="mt-2 text-gray-400">┌─ <span class="text-green-400 font-bold">Installed</span> ─ ★ Favorites ─ Updates ─ Discover ─ Backup ─ Dashboard ─ Config ─┐</p>
        <p class="text-gray-400">│</p>
        <p class="text-gray-400">│  <span class="text-green-400">✓</span> az          2.67.0    <span class="text-gray-600">(brew)</span>     Azure CLI</p>
        <p class="text-gray-400">│  <span class="text-yellow-400">⬆</span> docker      24.0.7    <span class="text-gray-600">(manual)</span>   Docker CLI          <span class="text-yellow-400">→ 27.1.0</span></p>
        <p class="text-gray-400">│  <span class="text-green-400">✓</span> git         2.47.0    <span class="text-gray-600">(brew)</span>     Git</p>
        <p class="text-gray-400">│  <span class="text-green-400">✓</span> go          1.25.0    <span class="text-gray-600">(brew)</span>     Go</p>
        <p class="text-gray-400">│  <span class="text-yellow-400">⬆</span> kubectl     1.28.4    <span class="text-gray-600">(brew)</span>     Kubernetes CLI      <span class="text-yellow-400">→ 1.31.0</span></p>
        <p class="text-gray-400">│  <span class="text-green-400">✓</span> node        22.11.0   <span class="text-gray-600">(brew)</span>     Node.js</p>
        <p class="text-gray-400">│  <span class="text-green-400">✓</span> terraform   1.7.2     <span class="text-gray-600">(brew)</span>     Terraform</p>
        <p class="text-gray-400">│</p>
        <p class="text-gray-500">│  ↑↓ navigate  ←→ tab  * favorite  s sort  Enter detail  f filter  q quit</p>
        <p class="text-gray-400">└──────────────────────────────────────────────────────────────────────────┘</p>
      </div>
    </div>
  </div>
</section>
