---
---

<section id="install" class="py-20 md:py-32">
  <div class="mx-auto max-w-4xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Install in seconds
      </h2>
      <p class="mt-4 text-lg text-gray-400">
        Choose your platform and get started immediately.
      </p>
    </div>

    <div class="mt-12 space-y-6">
      <!-- macOS / Linux -->
      <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900/50">
        <div class="border-b border-gray-800 px-6 py-3">
          <h3 class="text-sm font-medium text-gray-300">🍎 macOS / 🐧 Linux — Quick Install</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-gray-950 p-4 font-mono text-sm text-green-400"><code>curl -fsSL https://raw.githubusercontent.com/nassiharel/klim/main/install.sh | bash</code></pre>
        </div>
      </div>

      <!-- Windows -->
      <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900/50">
        <div class="border-b border-gray-800 px-6 py-3">
          <h3 class="text-sm font-medium text-gray-300">🪟 Windows — PowerShell</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-gray-950 p-4 font-mono text-sm text-green-400"><code>irm https://raw.githubusercontent.com/nassiharel/klim/main/install.ps1 | iex</code></pre>
        </div>
      </div>

      <!-- Homebrew -->
      <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900/50">
        <div class="border-b border-gray-800 px-6 py-3">
          <h3 class="text-sm font-medium text-gray-300">🍺 Homebrew</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-gray-950 p-4 font-mono text-sm text-green-400"><code>brew install nassiharel/tap/klim</code></pre>
        </div>
      </div>

      <!-- Go install -->
      <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900/50">
        <div class="border-b border-gray-800 px-6 py-3">
          <h3 class="text-sm font-medium text-gray-300">🐹 Go Install</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-gray-950 p-4 font-mono text-sm text-green-400"><code>go install github.com/nassiharel/klim/cmd/klim@latest</code></pre>
        </div>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-gray-500">
      Pre-built binaries also available on
      <a href="https://github.com/nassiharel/klim/releases/latest" class="text-green-400 hover:text-green-300 underline" target="_blank" rel="noopener noreferrer">
        GitHub Releases
      </a>
      for macOS, Linux, and Windows (amd64 & arm64).
    </p>
  </div>
</section>
